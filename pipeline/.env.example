# ─────────────────────────────────────────────────────────────
#  COPA — variáveis de ambiente do pipeline (APENAS LOCAL)
#  Copie este arquivo para  pipeline/.env  e preencha com suas chaves.
#  O .env real é ignorado pelo Git (.gitignore) e NUNCA vai p/ produção.
# ─────────────────────────────────────────────────────────────

# Token gratuito da football-data.org (competição WC).
# Crie em: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# Chave da OpenAI (usada só para gerar os textos das análises).
# Deixe em branco para rodar o pipeline sem IA.
OPENAI_API_KEY=

# Modelo da OpenAI (opcional; default abaixo).
OPENAI_MODEL=gpt-4o-mini
